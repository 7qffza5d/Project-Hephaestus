generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  ADMIN
}

enum PostType {
  BLOG
  NOTE
}

enum Visibility {
  PRIVATE
  CLASS
  SHARED
}

enum Language {
  PYTHON
  C
  CPP
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(STUDENT)
  createdAt    DateTime  @default(now())
  completions HomeworkCompletion[]

  posts        Post[]
  snippets     CodeSnippet[]
  homework     HomeworkItem[]
  events       Event[]
  accounts     Account[]
  sessions     Session[]
  files FileItem[]
}

model Post {
  id          String     @id @default(uuid())
  author      User       @relation(fields: [authorId], references: [id])
  authorId    String
  type        PostType
  title       String
  body        String
  visibility  Visibility @default(PRIVATE)
  shareToken  String?    @unique @default(uuid())
  createdAt   DateTime   @default(now())
}

model CodeSnippet {
  id          String     @id @default(uuid())
  author      User       @relation(fields: [authorId], references: [id])
  authorId    String
  title       String
  language    Language
  code        String
  lastOutput  String?
  visibility  Visibility @default(PRIVATE)
  createdAt   DateTime   @default(now())
}

model HomeworkItem {
  id         String   @id @default(uuid())
  createdBy  User     @relation(fields: [userId], references: [id])
  userId     String
  title      String
  subject    String
  dueDate    DateTime
  fileItemId String?
  fileItem   FileItem? @relation(fields: [fileItemId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  completions HomeworkCompletion[]
}

model Event {
  id          String   @id @default(uuid())
  createdBy   User     @relation(fields: [userId], references: [id])
  userId      String
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime?
  createdAt   DateTime @default(now())
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model HomeworkCompletion {
  userId         String
  homeworkItemId String
  completedAt    DateTime @default(now())

  user     User         @relation(fields: [userId], references: [id])
  homework HomeworkItem @relation(fields: [homeworkItemId], references: [id])

  @@id([userId, homeworkItemId])
}

model Folder {
  id        String     @id @default(uuid())
  name      String
  createdAt DateTime   @default(now())
  files     FileItem[]
}

model FileItem {
  id           String        @id @default(uuid())
  folderId     String
  uploaderId   String
  name         String
  url          String
  size         Int
  mimeType     String
  createdAt    DateTime      @default(now())
  folder       Folder        @relation(fields: [folderId], references: [id], onDelete: Cascade)
  uploader     User          @relation(fields: [uploaderId], references: [id])
  homeworkItems HomeworkItem[]
}